{
  "name": "jz",
  "version": "0.4.0",
  "description": "Modern functional JS compiling to WASM",
  "main": "index.js",
  "type": "module",
  "exports": {
    ".": "./index.js",
    "./wasi": "./wasi.js",
    "./interop": "./interop.js"
  },
  "files": [
    "index.js",
    "cli.js",
    "wasi.js",
    "interop.js",
    "src",
    "module",
    "README.md"
  ],
  "bin": {
    "jz": "cli.js"
  },
  "scripts": {
    "test": "node test/index.js",
    "test262": "node test/test262.js",
    "test262:builtins": "node test/test262-builtins.js",
    "bench": "node bench/bench.mjs",
    "bench:size": "node scripts/bench-size.mjs",
    "bench:compile": "node scripts/bench-compile.mjs",
    "build:examples": "for dir in examples/*; do node \"$dir/build.mjs\"; done",
    "test:bench": "node test/bench.js",
    "test:all": "npm test && npm run test:bench",
    "prepublishOnly": "npm run test:all"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dy/jz.git"
  },
  "bugs": {
    "url": "https://github.com/dy/jz/issues"
  },
  "homepage": "https://github.com/dy/jz#readme",
  "author": "Dmitry Iv",
  "license": "MIT",
  "dependencies": {
    "subscript": "^10.4.12",
    "watr": "^4.6.8"
  },
  "keywords": [
    "javascript",
    "webassembly",
    "compiler",
    "functional",
    "minimal",
    "wasm"
  ],
  "devDependencies": {
    "tst": "^9.4.0"
  }
}
